# BUILDICS（Base64 エンコーディング済みキーをそのまま設定）
# 組織ごとのキーは管理画面または Firestore orgs.buildicsApiKey で設定可能。未設定 org はここをフォールバックに使用
BUILDICS_API_KEY=

# ロゴ URL の追加許可ホスト（カンマ区切り）。例: cdn.example.com,*.cdn.example.com
# LOGO_URL_ALLOWED_HOSTS=

# JWT（本番は必ず強い乱数を別々に）
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# CORS（カンマ区切り）
ALLOWED_ORIGINS=http://localhost:5173

DEFAULT_ORG_ID=default

# 公開URL /o/<slug> のフォールバック（orgs に slug が無いときこのスラッグだけ DEFAULT_ORG_ID に解決）
DEFAULT_ORG_SLUG=default

# 初回管理者作成 POST /api/auth/bootstrap 用（本番では強力な値に）
AUTH_BOOTSTRAP_SECRET=

# ローカル: `cd functions && npm run serve` は Firestore エミュレータも起動する（functions のみだと DB が本番向きになり login 401 になりやすい）
#
# ローカル自動登録: エミュレータ起動後に `npm run seed:admin`（.env に以下を書いたうえで）
# SEED_ADMIN_EMAIL=admin@localhost.local
# SEED_ADMIN_PASSWORD=<8文字以上>
# 同一コマンドで superadmin を作る / 昇格する場合（例: 上と同じメールで初回 admin のまま昇格）
# SEED_SUPERADMIN_EMAIL=admin@localhost.local
# SEED_SUPERADMIN_PASSWORD=   ← 省略可（既存ユーザー昇格時パスワードは変えない）。新規メールのみなら8文字以上必須
# （ポートがずれる場合） FUNCTIONS_EMULATOR_URL=http://127.0.0.1:5001/<project>/asia-northeast1/api
# 本番 Cookie
COOKIE_SECURE=false

# デモ予報 UI（true で有効）
SHOW_DEMO_FORECAST=false

# 台帳が空の間はスコープ検証スキップ。強制スキップは non-production のみ推奨
# RELAX_DEVICE_SCOPE=true
