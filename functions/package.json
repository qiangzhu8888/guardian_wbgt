{
  "name": "functions",
  "version": "0.1.0",
  "description": "WBGT監視システム - Cloud Functions（BUILDICSプロキシ）",
  "scripts": {
    "serve": "firebase emulators:start --only functions,firestore",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log",
    "test": "jest",
    "seed:admin": "node scripts/seed-admin.cjs"
  },
  "engines": {
    "node": "22"
  },
  "main": "index.js",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.7",
    "express": "^4.21.2",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^7.2.5",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "dotenv": "^16.4.5",
    "firebase-functions-test": "^3.1.0",
    "jest": "^29.7.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "forceExit": true
  },
  "private": true
}
