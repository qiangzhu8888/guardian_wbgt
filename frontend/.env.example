# BUILDICS API 設定（開発環境専用）
# BUILDICSの管理画面からAPIキーを取得して設定してください
VITE_BUILDICS_API_KEY=<BUILDICSの管理画面から取得>

# 開発時のAPIベースURL（Viteプロキシ経由。通常は変更不要）
VITE_BUILDICS_API_BASE=/buildics-api

# ─────────────────────────────────────────────
# 本番環境設定は .env.production で管理
# VITE_BUILDICS_PROXY_URL=https://asia-northeast1-wgbt-monitor.cloudfunctions.net/buildicsProxy
# ─────────────────────────────────────────────
