# Firebase Web（任意・Google Analytics 用。未設定なら初期化しません）
# Console の「プロジェクトの設定」→ マイアプリ の設定値をコピー
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=
# VITE_FIREBASE_MEASUREMENT_ID=

# BUILDICS API 設定
# ─ 開発でブラウザから直叩きする場合のみ設定（推奨されない）。未設定なら /api/buildics（BFF）経由。
# VITE_BUILDICS_API_KEY=
# VITE_BUILDICS_API_BASE=/buildics-api

# BFF のベース（例: 別ホストにデプロイ済みのとき）
# VITE_API_BASE=

# 管理画面から「公開監視 URL」を表示するときのオリジン（未設定なら現在のブラウザ origin）
# 例: VITE_PUBLIC_APP_ORIGIN=https://wbgt-monitor-d5556.web.app
# VITE_PUBLIC_APP_ORIGIN=

# 「/」からリダイレクトする監視テナントのスラッグ（Functions の DEFAULT_ORG_SLUG と揃える）
# VITE_DEFAULT_ORG_SLUG=default

# ─────────────────────────────────────────────
# 本番: 相対パス /api のみでよい（追加の VITE_ シークレットは不要）
# ─────────────────────────────────────────────
